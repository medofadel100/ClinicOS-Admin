# .env.example
# Do not commit .env.local with real values!

# Supabase Public (Client-safe)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Server-only (DO NOT leak to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# License Private Key (DO NOT leak to browser, Server-only)
LICENSE_PRIVATE_KEY=your_ed25519_private_key_pem_here
